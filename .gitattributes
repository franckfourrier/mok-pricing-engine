# =============================================
# Base : Normalisation automatique
# =============================================
* text=auto

# =============================================
# Code Source
# =============================================
*.java text eol=lf
*.kt text eol=lf
*.groovy text eol=lf
*.xml text eol=lf
*.json text eol=lf

# =============================================
# Configuration & Documentation
# =============================================
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf

# =============================================
# Scripts
# =============================================
*.sh text eol=lf
*.bash text eol=lf

# Scripts Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# =============================================
# Build & Maven/Gradle
# =============================================
pom.xml text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
mvnw text eol=lf
mvnw.cmd text eol=crlf

# =============================================
# Fichiers Binaires (ne pas toucher les fins de ligne)
# =============================================
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.db binary
*.sqlite binary

# =============================================
# Docker & Git
# =============================================
.gitattributes text eol=lf
.gitignore text eol=lf
Dockerfile text eol=lf
*.dockerignore text eol=lf