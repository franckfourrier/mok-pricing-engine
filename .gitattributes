# Normaliser automatiquement les fichiers texte
* text=auto

# Code source
*.java          text eol=lf
*.kt            text eol=lf
*.groovy        text eol=lf

# Configuration
*.xml           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.properties    text eol=lf
*.json          text eol=lf
*.md            text eol=lf
*.txt           text eol=lf
*.sql           text eol=lf

# Scripts Linux
*.sh            text eol=lf

# Build tools
*.gradle        text eol=lf
*.gradle.kts    text eol=lf
pom.xml         text eol=lf
build.gradle    text eol=lf

# Maven wrapper
mvnw            text eol=lf
mvnw.cmd        text eol=crlf

# Scripts Windows
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binaires
*.jar           binary
*.war           binary
*.ear           binary
*.zip           binary
*.tar.gz        binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary
*.docx          binary
*.xlsx          binary